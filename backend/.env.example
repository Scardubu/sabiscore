# =============================================================================
# SabiScore Backend Environment Configuration Template
# =============================================================================
# Copy to .env (gitignored) and populate with your credentials.
# Never commit real secrets — keys belong in .env only.
#
# Local dev without PostgreSQL: set ALLOW_SQLITE_FALLBACK=true below.
# =============================================================================

# --- Database ----------------------------------------------------------------
DATABASE_URL=postgresql://sabi@localhost:5432/sabiscore

# --- Redis Cache -------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Security ----------------------------------------------------------------
SECRET_KEY=your-secret-key-here

# --- Application -------------------------------------------------------------
APP_ENV=development
DEBUG=false
MOCK_MODE=false
LOG_LEVEL=INFO
ENABLE_LEGACY_INFERENCE=false
ALLOW_SQLITE_FALLBACK=false
SCRAPER_ALLOW_INSECURE_FALLBACK=false

# --- Provider Credentials (backend-only, never NEXT_PUBLIC_) -----------------
# ESPN: keyless — no key variable needed.
# football-data.org X-Auth-Token (free tier: sign up at football-data.org)
FOOTBALL_DATA_API_KEY=
# API-Football api key (header: x-apisports-key; free tier: 100 req/day)
# Also accepted: API_FOOTBALL_KEY (legacy alias)
API_FOOTBALL_API_KEY=
# Sportmonks api_token (free tier, sign up at sportmonks.com)
# Also accepted: SPORTMONKS_API_KEY (legacy alias)
SPORTMONKS_API_TOKEN=
# The Odds API apiKey (free tier: 500 credits/month)
# Also accepted: ODDS_API_KEY (legacy alias)
THE_ODDS_API_KEY=

# --- Provider Enable Flags ---------------------------------------------------
# ESPN is keyless and always enabled.
# Set each keyed provider to true once its credential above is populated.
ENABLE_ESPN_PROVIDER=true
ENABLE_FOOTBALL_DATA_PROVIDER=false
ENABLE_API_FOOTBALL_PROVIDER=false
ENABLE_SPORTMONKS_PROVIDER=false
ENABLE_THE_ODDS_API_PROVIDER=false
PROVIDER_LIVE_TESTS=false
PROVIDER_REQUEST_BUDGET_ENABLED=true

# --- Free-Tier Quota Limits (advisory governance) ----------------------------
FOOTBALL_DATA_DAILY_REQUEST_LIMIT=430
API_FOOTBALL_DAILY_REQUEST_LIMIT=95
THE_ODDS_API_MONTHLY_CREDIT_LIMIT=480

# --- Phase Gates (safe defaults) ---------------------------------------------
USE_PHASE9_CANDIDATE_FEATURES=false
PHASE9_SHADOW_ONLY=true
PHASE9_SOURCES_PATH=data/processed/v4_sources
PHASE8_CANARY_PCT=0.0
PHASE8_ENRICHMENT_SHADOW=false
USE_PHASE8_FEATURES=true
ODDS_STALENESS_MAX_HOURS=24
LIVE_THRESHOLD_SECONDS=3600
EDGE_QUALITY_ABSTAIN_THRESHOLD=0.30
