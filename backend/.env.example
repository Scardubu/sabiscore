# Database
DATABASE_URL=

# Redis Cache
REDIS_URL=

# Canonical provider credentials
# ESPN uses selected keyless public endpoints and must not be configured with a key.
FOOTBALL_DATA_API_KEY=your_key_here
API_FOOTBALL_API_KEY=your_key_here
SPORTMONKS_API_TOKEN=your_key_here
THE_ODDS_API_KEY=your_key_here
ENABLE_ESPN_PROVIDER=true
ENABLE_FOOTBALL_DATA_PROVIDER=true
ENABLE_API_FOOTBALL_PROVIDER=false
ENABLE_SPORTMONKS_PROVIDER=false
ENABLE_THE_ODDS_API_PROVIDER=false
PROVIDER_LIVE_TESTS=false
PROVIDER_REQUEST_BUDGET_ENABLED=true

# Security
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_ENV=development
DEBUG=false
MOCK_MODE=false
LOG_LEVEL=INFO
ENABLE_LEGACY_INFERENCE=false
SCRAPER_ALLOW_INSECURE_FALLBACK=false
ALLOW_SQLITE_FALLBACK=false

# Scraping
USER_AGENT=SabiScore/1.0 (contact@sabiscore.com)
REQUEST_TIMEOUT=10
RATE_LIMIT_DELAY=1.0

# V4 / Phase 9 candidate source layer (safe defaults)
USE_PHASE9_CANDIDATE_FEATURES=false
PHASE9_SHADOW_ONLY=true
PHASE9_SOURCES_PATH=data/processed/v4_sources

# Phase 8 safety controls
USE_PHASE8_FEATURES=false
PHASE8_ENRICHMENT_SHADOW=true
PHASE8_CANARY_PCT=0.0
ODDS_STALENESS_MAX_HOURS=24
LIVE_THRESHOLD_SECONDS=3600
EDGE_QUALITY_ABSTAIN_THRESHOLD=0.30
