# Database
DATABASE_URL=postgresql://username:password@localhost:5432/sabiscore

# Redis Cache
REDIS_URL=redis://default:password@localhost:6379

# External APIs
ESPN_API_KEY=your_espn_api_key
OPTA_API_KEY=your_opta_api_key
BETFAIR_APP_KEY=your_betfair_app_key
FIVETHIRTYEIGHT_API_KEY=your_fivethirtyeight_api_key

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Scraping
USER_AGENT=SabiScore/1.0 (contact@sabiscore.com)
REQUEST_TIMEOUT=10
RATE_LIMIT_DELAY=1.0

# ============================================================================
# ULTRA ML Configuration (High-Performance Predictions)
# ============================================================================

# Path to trained Ultra ML models
ULTRA_MODEL_PATH=./models/ultra_ensemble

# Enable Ultra predictions (set to false to use legacy only)
USE_ULTRA_MODEL=true

# Ultra prediction cache TTL (seconds)
ULTRA_CACHE_TTL=300

# Ultra API rate limit (requests per minute per IP)
ULTRA_RATE_LIMIT=100

# Ultra model version identifier
ULTRA_MODEL_VERSION=v3.0.0-ultra

# ==========================================================================
# Phase 7 Expanded Feature Models (68-Dim)
# ==========================================================================

# Enable v5_phase7 artifacts in prediction routing
USE_PHASE7_MODELS=true

# Deterministic per-league canary rollout percentage (0.0 - 1.0)
PHASE7_CANARY_PCT=1.0

# Paths for model and data artifacts
PHASE7_MODELS_PATH=./backend/models
ELO_PARQUET_PATH=./data/processed/elo_ratings.parquet
STATSBOMB_CACHE_PATH=./data/processed/statsbomb_features_cache.parquet
STATSBOMB_STALENESS_MAX_DAYS=7

# V4 / Phase 9 candidate source layer
# Default is safe: disabled and shadow-only.
USE_PHASE9_CANDIDATE_FEATURES=false
PHASE9_SHADOW_ONLY=true
PHASE9_SOURCES_PATH=data/processed/v4_sources

# Optional source credentials
FOOTBALL_DATA_API_KEY=
API_FOOTBALL_KEY=
SPORTMONKS_API_KEY=
THE_ODDS_API_KEY=

# Existing safety controls should remain enabled
USE_PHASE8_FEATURES=true
PHASE8_ENRICHMENT_SHADOW=false
ODDS_STALENESS_MAX_HOURS=24

# Recommended rollout gates
PHASE8_CANARY_PCT=0.0
LIVE_THRESHOLD_SECONDS=3600
EDGE_QUALITY_ABSTAIN_THRESHOLD=0.30
