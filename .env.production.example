# Production Environment Variables
# Copy this file to .env.production and fill in the values

# Database
DATABASE_URL=
DB_PASSWORD=

# Redis
REDIS_URL=

# Security
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Canonical service URLs
SABISCORE_BACKEND_URL=https://sabiscore-api.onrender.com
NEXT_PUBLIC_APP_URL=https://sabiscore.vercel.app
BACKEND_TOKEN=

# Application
APP_ENV=production
DEBUG=false
MOCK_MODE=false
LOG_LEVEL=INFO
ENABLE_SECURITY_HEADERS=true

# Evidence acquisition
ENABLE_NODE_SCRAPER=true
ENABLE_DYNAMIC_SCRAPERS=false
ENABLE_OPTIONAL_FREE_KEY_PROVIDERS=false
ENABLE_WEATHER=false
ENABLE_LEGACY_INFERENCE=false
SCRAPER_ALLOW_INSECURE_FALLBACK=false
ALLOW_SQLITE_FALLBACK=false
PROVIDER_LIVE_TESTS=false
PROVIDER_REQUEST_BUDGET_ENABLED=true
SCRAPER_MODE=fixture
SCRAPER_DATA_ROOT=./data
SCRAPER_PROCESSED_ROOT=./data/processed/node-scraper
SCRAPER_USER_AGENT=SabiScoreDataResearch/1.0
SCRAPER_MAX_CONCURRENCY=2

# Optional providers stay disabled by default. Production decisions must fail closed
# when a coherent evidence bundle or market snapshot is unavailable.
FOOTBALL_DATA_API_KEY=
API_FOOTBALL_KEY=
SPORTMONKS_API_KEY=
THE_ODDS_API_KEY=
ENABLE_ESPN_PROVIDER=true
ENABLE_FOOTBALL_DATA_PROVIDER=false
ENABLE_API_FOOTBALL_PROVIDER=false
ENABLE_SPORTMONKS_PROVIDER=false
ENABLE_THE_ODDS_API_PROVIDER=false

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# CORS
CORS_ORIGINS=https://sabiscore.com,https://www.sabiscore.com,https://sabiscore.vercel.app

# WebSocket
WS_PORT=8001
WS_HEARTBEAT_INTERVAL=30
