      "Bash(pnpm test:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm type-check:*)",
      "Bash(pnpm lint:*)",
      "Bash(npx tsc:*)",
      "Bash(npx prettier:*)",
      "Bash(node:*)",
      "Bash(make validate:*)",
      "Bash(make doctor:*)",
      "Bash(curl -s:*)",
      "Bash(find . -type f:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(python3 -c ' *)",
