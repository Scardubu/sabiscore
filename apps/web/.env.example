# SabiScore Web Environment
# Copy to .env.local for local development. Never commit real secrets.

SABISCORE_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public presentation flags only
NEXT_PUBLIC_CURRENCY=NGN
NEXT_PUBLIC_CURRENCY_SYMBOL=NGN
NEXT_PUBLIC_BASE_BANKROLL=10000
NEXT_PUBLIC_ENABLE_MONTE_CARLO=false

# Server-only backend proxy token, if enabled by the backend.
BACKEND_TOKEN=

# Provider credentials belong only on the FastAPI backend, never in apps/web.
# FOOTBALL_DATA_API_KEY=
# API_FOOTBALL_KEY=
# SPORTMONKS_API_KEY=
# THE_ODDS_API_KEY=

NEXT_TELEMETRY_DISABLED=1
NODE_ENV=development
