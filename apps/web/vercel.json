{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": ".next",
  "ignoreCommand": "exit 1",
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1",
      "NODE_OPTIONS": "--max-old-space-size=8192",
      "SABISCORE_BACKEND_URL": "https://sabiscore-api.onrender.com"
    }
  },
  "env": {
    "SABISCORE_BACKEND_URL": "https://sabiscore-api.onrender.com",
    "NEXT_PUBLIC_APP_URL": "https://sabiscore.com",
    "NEXT_PUBLIC_CURRENCY": "NGN",
    "NEXT_PUBLIC_CURRENCY_SYMBOL": "NGN",
    "NEXT_PUBLIC_BASE_BANKROLL": "10000"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/health",
      "destination": "https://sabiscore-api.onrender.com/health"
    },
    {
      "source": "/api/v1/:path*",
      "destination": "https://sabiscore-api.onrender.com/api/v1/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/health",
      "destination": "/api/health",
      "permanent": false
    }
  ]
}
