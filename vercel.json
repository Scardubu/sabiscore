{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @sabiscore/web build",
  "devCommand": "pnpm --filter @sabiscore/web dev",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "apps/web/.next",
  "ignoreCommand": "node scripts/vercel-ignore-build.mjs",
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1",
      "NODE_OPTIONS": "--max-old-space-size=8192",
      "NEXT_PUBLIC_API_URL": "/api",
      "SABISCORE_BACKEND_URL": "https://sabiscore-api.onrender.com",
      "NEXT_PUBLIC_APP_URL": "https://sabiscore.vercel.app"
    }
  },
  "env": {
    "NEXT_PUBLIC_API_URL": "/api",
    "NEXT_PUBLIC_CURRENCY": "NGN",
    "NEXT_PUBLIC_CURRENCY_SYMBOL": "\u20a6",
    "NEXT_PUBLIC_BASE_BANKROLL": "10000",
    "NEXT_PUBLIC_KELLY_FRACTION": "0.125",
    "NEXT_PUBLIC_MIN_EDGE_NGN": "66",
    "SABISCORE_BACKEND_URL": "https://sabiscore-api.onrender.com",
    "NEXT_PUBLIC_APP_URL": "https://sabiscore.vercel.app"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/health",
      "destination": "https://sabiscore-api.onrender.com/health"
    },
    {
      "source": "/api/v1/:path*",
      "destination": "https://sabiscore-api.onrender.com/api/v1/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/health",
      "destination": "/api/health",
      "permanent": false
    }
  ]
}
