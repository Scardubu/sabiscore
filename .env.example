# SabiScore production-safe environment template

# Canonical service URLs
SABISCORE_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Browser-safe display defaults
NEXT_PUBLIC_CURRENCY=NGN
NEXT_PUBLIC_CURRENCY_SYMBOL=NGN
NEXT_PUBLIC_BASE_BANKROLL=10000

# Backend/runtime safety defaults
APP_ENV=development
DEBUG=false
MOCK_MODE=false
ENABLE_LEGACY_INFERENCE=false
SCRAPER_ALLOW_INSECURE_FALLBACK=false
AUTO_CREATE_TABLES=false

# Scraper boundaries
ENABLE_NODE_SCRAPER=true
ENABLE_DYNAMIC_SCRAPERS=false
ENABLE_OPTIONAL_FREE_KEY_PROVIDERS=false
ENABLE_WEATHER=false
SCRAPER_MODE=fixture
SCRAPER_DATA_ROOT=./data
SCRAPER_USER_AGENT=SabiScoreDataResearch/1.0
SCRAPER_MAX_CONCURRENCY=2

# Backend-only provider credentials.
# ESPN is keyless. Do not configure a provider credential for ESPN.
FOOTBALL_DATA_API_KEY=
API_FOOTBALL_KEY=
SPORTMONKS_API_KEY=
THE_ODDS_API_KEY=

ENABLE_ESPN_PROVIDER=true
ENABLE_FOOTBALL_DATA_PROVIDER=false
ENABLE_API_FOOTBALL_PROVIDER=false
ENABLE_SPORTMONKS_PROVIDER=false
ENABLE_THE_ODDS_API_PROVIDER=false
PROVIDER_LIVE_TESTS=false
PROVIDER_REQUEST_BUDGET_ENABLED=true

# Optional infrastructure
DATABASE_URL=postgresql://username:password@localhost:5432/sabiscore
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-secret-key-here
CRON_SECRET=your-cron-secret-here
NEXT_TELEMETRY_DISABLED=1
