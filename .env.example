# SabiScore - Environment Template
# Copy to .env and fill in real values. Never commit .env.
# Updated: 2026-07-03 (SABI-CORE vO.1 Phase 1)

# -- Application --------------------------------------------------------------
APP_ENV=development
DEBUG=false
SECRET_KEY=your-secret-key-here
APP_NAME=SabiScore API

# -- Database -----------------------------------------------------------------
# Use a strong password in production; the short placeholder below is intentional.
DATABASE_URL=postgresql://sabi:devpass@localhost:5432/sabiscore
# ALLOW_SQLITE_FALLBACK=true  # development/test opt-in only; never in production

# -- Cache --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# UPSTASH_REDIS_URL=rediss://default:token@hostname:port  # optional serverless tier

# -- Frontend proxy -----------------------------------------------------------
# Next.js proxies all provider traffic through this URL.
SABISCORE_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CURRENCY=USD
NEXT_PUBLIC_CURRENCY_SYMBOL=$
NEXT_PUBLIC_BASE_BANKROLL=100

# -- Provider credentials (backend-only; NEVER NEXT_PUBLIC_*) -----------------
#
# football-data.org | fixtures, results, standings | X-Auth-Token header
# Free: 10 req/min, 12 competitions | https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_key_here

# API-Football (api-sports.io) | injuries, lineups, team stats | x-apisports-key header
# Free: 100 req/day, all competitions | https://dashboard.api-football.com/register
API_FOOTBALL_API_KEY=your_key_here
# Legacy alias also accepted: API_FOOTBALL_KEY=

# Sportmonks | supplementary injuries, lineups | api_token query param
# Free: Danish Superliga + Scottish Premiership only | https://my.sportmonks.com/register
SPORTMONKS_API_TOKEN=your_key_here
# Legacy alias also accepted: SPORTMONKS_API_KEY=

# The Odds API | 1X2 bookmaker snapshots | apiKey query param
# Free: 500 credits/month (cost = markets x regions) | https://the-odds-api.com/#get-access
THE_ODDS_API_KEY=your_key_here
# Legacy alias also accepted: ODDS_API_KEY=

# ESPN: keyless - no key needed. Supplementary fixture discovery only.

# -- Provider activation (set to true after adding the key above) -------------
ENABLE_ESPN_PROVIDER=true
ENABLE_FOOTBALL_DATA_PROVIDER=true
ENABLE_API_FOOTBALL_PROVIDER=false
ENABLE_SPORTMONKS_PROVIDER=false
ENABLE_THE_ODDS_API_PROVIDER=false

# -- Provider quota governance (free-tier protection) -------------------------
# Leave unset for unlimited. Set to your plan's actual daily/monthly limit.
# football-data.org free: ~10 req/min across 12 competitions
FOOTBALL_DATA_DAILY_REQUEST_LIMIT=
# API-Football free: 100 req/day
API_FOOTBALL_DAILY_REQUEST_LIMIT=100
# Sportmonks: per-entity per-hour (Starter 2000, Growth 2500, Pro 3000)
SPORTMONKS_DAILY_REQUEST_LIMIT=
# The Odds API free: 500 credits/month
THE_ODDS_API_MONTHLY_CREDIT_LIMIT=500

# -- Provider gateway operational settings ------------------------------------
PROVIDER_LIVE_TESTS=false
PROVIDER_REQUEST_TIMEOUT_SECONDS=12
PROVIDER_MAX_RETRIES=2
PROVIDER_CACHE_ENABLED=true
PROVIDER_STRICT_QUOTA_MODE=true
PROVIDER_FAIL_CLOSED=true
PROVIDER_REQUEST_BUDGET_ENABLED=true

# -- Safe defaults (production fail-closed) -----------------------------------
MOCK_MODE=false
ENABLE_LEGACY_INFERENCE=false
SCRAPER_ALLOW_INSECURE_FALLBACK=false
ALLOW_SQLITE_FALLBACK=false
USE_PHASE9_CANDIDATE_FEATURES=false
PHASE9_SHADOW_ONLY=true

# -- Feature flags ------------------------------------------------------------
USE_ENHANCED_MODELS=true
USE_OPTUNA_V4=true
USE_PHASE7_MODELS=false
PHASE7_CANARY_PCT=0.0
USE_PHASE8_MODELS=false
USE_PHASE8_FEATURES=false
PHASE8_CANARY_PCT=0.0
UCL_LOW_EVIDENCE_OVERRIDE=true

# -- Observability ------------------------------------------------------------
# SENTRY_DSN=https://your_dsn@o123.ingest.sentry.io/456

# -- CORS (comma-separated or JSON array) -------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
